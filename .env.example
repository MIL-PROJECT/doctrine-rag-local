# 원격 Ollama (Colab + ngrok). Docker 백엔드는 공개 HTTPS URL 이 필요합니다.
OLLAMA_BASE_URL=https://chomp-ethics-dazzling.ngrok-free.dev
OLLAMA_MODEL=qwen3:8b
# 채팅 읽기 타임아웃(초). OLLAMA_TIMEOUT_SECONDS 로도 지정 가능.
OLLAMA_TIMEOUT=180
# 각 군(army/navy/air_force) 에이전트 답변용 토큰 상한.
OLLAMA_MAX_TOKENS=512
# GET /api/tags 헬스 프로브 타임아웃(초)
OLLAMA_HEALTHCHECK_TIMEOUT=10

# 로컬 SentenceTransformers 모델 (Hugging Face id)
EMBEDDING_MODEL=BAAI/bge-m3
# 임베딩 인퍼런스 배치 크기 (OOM 완화용)
# EMBEDDING_BATCH_SIZE=8

TOP_K_MAX=20
RAG_CHUNK_CHAR_LIMIT=1200
RAG_CONTEXT_CHAR_LIMIT=4500
# Hybrid Query Router 의 auto 모드에서 RAG 판정에 쓰는 거리 임계값
# RETRIEVAL_MAX_DISTANCE=0.75

CHROMA_DIR=chroma_db
# 레거시: 단일 컬렉션 명 (현 backend 는 아래 군별 컬렉션을 사용)
CHROMA_COLLECTION_NAME=doctrine_ollama
# 군별 Chroma 컬렉션 (다중 브랜치 라우팅). 미설정 시 기본값 사용.
# CHROMA_COLLECTION_ARMY=army_doctrine
# CHROMA_COLLECTION_NAVY=navy_doctrine
# CHROMA_COLLECTION_AIR_FORCE=air_force_doctrine

CHUNKS_DATA_DIR=data/chunks
# CHUNK_TEXT_COLUMN=embedding_text
# INGEST_BATCH_SIZE=64

CORS_ORIGINS=*

LOG_LEVEL=INFO

# A2A 캐시 (발표 시연 안정화용). true 일 때만 캐시 동작.
A2A_CACHE_ENABLED=false

# A2A 완료 시 로컬 해시 체인 원장(JSONL) 기록. false 권장(개발) — true 시 backend/logs/local_ledger.jsonl 에 append
A2A_BLOCKCHAIN_ENABLED=false

NEXT_PUBLIC_API_URL=http://localhost:8000
# 프론트 Route Handler의 top_k 상한 (백엔드 TOP_K_MAX와 맞추는 것을 권장)
NEXT_PUBLIC_TOP_K_MAX=20

# -----------------------------------------------------------------------------
# Colab 부팅 모드 (notebooks/colab_boot.ipynb)
# -----------------------------------------------------------------------------
# Colab GPU 한 대에서 Ollama + FastAPI 백엔드를 같이 띄우는 구성입니다.
# 위 Docker 워크플로우와 충돌하지 않도록 별도 주석으로 둡니다.
# 노트북은 아래 값을 자동으로 작성하므로, 본 파일을 직접 수정할 필요는 없습니다.
#
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b
# CHROMA_DIR=chroma_db
# CHROMA_COLLECTION_ARMY=army_doctrine
# CHROMA_COLLECTION_NAVY=navy_doctrine
# CHROMA_COLLECTION_AIR_FORCE=airforce_doctrine   # Drive zip 명명과 일치시키기 위한 오버라이드
# CORS_ORIGINS=*
# LOG_LEVEL=INFO
