# Ollama (Docker 네트워크 내 서비스명)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=300

# 로컬 SentenceTransformers 모델 (Hugging Face id)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 청킹
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K_MAX=20

# Chroma
CHROMA_DIR=chroma_db
CHROMA_COLLECTION_NAME=doctrine_ollama

# 교리 원문 디렉터리 (컨테이너 기준 경로; compose에서 호스트와 마운트)
DOCTRINE_DATA_DIR=data/doctrine

# CORS (쉼표 구분)
CORS_ORIGINS=*

LOG_LEVEL=INFO

# 브라우저에서 접근하는 API URL (프론트 빌드 시 주입)
NEXT_PUBLIC_API_URL=http://localhost:8000
