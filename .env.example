# Ollama (Docker 네트워크 내 서비스명)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=300

# 로컬 SentenceTransformers 모델 (Hugging Face id) — BGE-M3 권장
EMBEDDING_MODEL=BAAI/bge-m3

TOP_K_MAX=20

# Chroma
CHROMA_DIR=chroma_db
CHROMA_COLLECTION_NAME=doctrine_ollama

# 전처리 RAG 청크 CSV 디렉터리 (backend 기준; 예: All_RAG_Chunks.csv)
CHUNKS_DATA_DIR=data/chunks
# 비우면 embedding_text → chunk_text → content 순으로 본문 컬럼 자동 선택
# CHUNK_TEXT_COLUMN=embedding_text

# 대용량 CSV 인제스트 시 한 번에 임베딩·저장할 행 수 (메모리 조절)
# INGEST_BATCH_SIZE=64

# CORS (쉼표 구분)
CORS_ORIGINS=*

LOG_LEVEL=INFO

# 브라우저에서 접근하는 API URL (프론트 빌드 시 주입)
NEXT_PUBLIC_API_URL=http://localhost:8000
